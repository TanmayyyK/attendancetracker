APP_NAME=attendace-api
API_PREFIX=/api
TARGET_ATTENDANCE=75

# Seamless continuity with your existing local SQLite file:
# Keep attendance_ultra.db inside backend/ OR set absolute path below.
DATABASE_URL=sqlite:///./attendance_ultra.db

# Turso option (after import/migration):
